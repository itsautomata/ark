#!/bin/bash
# ark CLI. runs everything in Docker.
#
# first time:  ./ark_docker setup     (builds image, starts ollama, pulls gemma)
# then:        ./ark_docker ref flairr_ts
#              ./ark_docker claim flairr_ts
#              ./ark_docker inflate flairr_ts
# stop:        ./ark_docker down

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SCRIPT_DIR"

MODEL="${ARK_MODEL:-gemma4:e4b}"

case "${1:-}" in
    setup)
        echo "building ark image..."
        docker compose build ark

        echo "starting ollama..."
        docker compose up -d ollama

        echo "waiting for ollama..."
        until curl -sf http://localhost:11434/api/tags > /dev/null 2>&1; do
            sleep 1
        done

        echo "pulling $MODEL..."
        docker compose exec ollama ollama pull "$MODEL"

        echo ""
        echo "ready. run:"
        echo "  ./ark_docker ref flairr_ts"
        echo "  ./ark_docker claim flairr_ts"
        echo "  ./ark_docker inflate flairr_ts"
        ;;

    down)
        docker compose down
        echo "stopped."
        ;;

    status)
        if docker compose ps ollama 2>/dev/null | grep -q "Up"; then
            echo "ollama: running"
            if curl -sf http://localhost:11434/api/tags | grep -q "$MODEL"; then
                echo "model: $MODEL ready"
            else
                echo "model: $MODEL not pulled. run ./ark_docker setup"
            fi
        else
            echo "ollama: not running. run ./ark_docker setup"
        fi
        ;;

    ""|help|-h|--help)
        echo "usage:"
        echo "  ./ark_docker setup              build + start ollama + pull gemma"
        echo "  ./ark_docker ref <fixture>       check citations"
        echo "  ./ark_docker claim <fixture>     extract claims"
        echo "  ./ark_docker inflate <fixture>   score inflation"
        echo "  ./ark_docker status             check if ollama + gemma are ready"
        echo "  ./ark_docker down               stop everything"
        ;;

    *)
        if ! docker compose ps ollama 2>/dev/null | grep -q "Up"; then
            echo "ollama not running. run ./ark_docker setup first."
            exit 1
        fi
        docker compose run --rm ark "$@"
        ;;
esac
